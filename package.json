{
  "name": "environment-favicon-switcher",
  "version": "2.3.0",
  "description": "Browser extension that makes development environments immediately identifiable through favicons, badges and title prefixes.",
  "private": true,
  "scripts": {
    "vendor:icons": "node scripts/vendor-icons.mjs",
    "postinstall": "npm run vendor:icons",
    "lint": "node scripts/check.mjs && npm run release:check",
    "test": "node --test",
    "validate": "npm run lint && npm test",
    "package:extension": "npm run vendor:icons && node scripts/package.mjs",
    "build": "npm run validate && npm run package:extension",
    "release:check": "node scripts/release.mjs check",
    "release:plan": "node scripts/release.mjs plan",
    "release:prepare": "node scripts/release.mjs prepare",
    "release:notes": "node scripts/release.mjs notes",
    "release:publish-check": "node scripts/publish.mjs check",
    "package:verify": "node scripts/verify-package.mjs",
    "pr:check": "node scripts/check-pr.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@phosphor-icons/web": "^2.1.2"
  }
}
